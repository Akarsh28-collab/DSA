/**
 * @input A : Integer array
 * @input n1 : Integer array's ( A ) length
 * @input B : Integer
 * 
 * @Output Integer
 */
int solve(int* A, int n1, int B) {
    int st=0;
    int end=1;
    
    if(B<0){
        B*=-1;
    }
    while(end<n1){
        if(A[end]-A[st]==B){
            return 1;
        }
        else if(A[end]-A[st]<B){
            end++;
        }
        else{
            st++;
        }
    }
    if(st==end){
        end++;
    }
    return 0;
}
